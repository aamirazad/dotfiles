#!/bin/sh

# Reuse the oldest detached session. If every session is currently attached,
# create a new numbered one so separate Kitty windows do not mirror it.
detached_session=$(
    tmux list-sessions -F '#{session_created}:#{session_attached}:#{session_name}' 2>/dev/null |
        awk -F ':' '$2 == 0 { print $1 ":" $3 }' |
        sort -n |
        head -n 1 |
        cut -d ':' -f 2-
)

if [ -n "$detached_session" ]; then
    exec tmux attach-session -t "$detached_session"
fi

next_session=$(
    tmux list-sessions -F '#{session_name}' 2>/dev/null |
        awk '/^[0-9]+$/ && $1 > highest { highest = $1 } END { print highest + 1 }'
)

next_session=${next_session:-1}

# Create the session without tying its lifetime to Kitty's first client.
# Closing the Kitty OS window then detaches the client while the session stays
# alive for the next invocation to discover and reattach.
if ! tmux new-session -d -s "$next_session"; then
    exit 1
fi

exec tmux attach-session -t "$next_session"
